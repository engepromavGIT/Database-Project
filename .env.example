# ============================================================
# Variáveis de ambiente — COPIE para .env e preencha.
# NUNCA versione o .env (já está no .gitignore).
# ============================================================

# Banco: use a connection string da BRANCH DE DEV do Neon (com -pooler).
# >>> Nunca aponte para o banco de PRODUÇÃO durante o desenvolvimento. <<<
# Ex.: postgresql://user:senha@ep-xxxx-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Segredo de assinatura dos JWT. Use EXATAMENTE o mesmo segredo do app Promav para
# que os logins sejam compatíveis (mesmo token). NÃO reutilize a senha do banco nem
# valores fracos/previsíveis. Em produção é obrigatório — o servidor recusa iniciar
# sem ele. Em dev, se vazio, o auth.js usa um fallback só-para-desenvolvimento.
JWT_SECRET=troque-pelo-mesmo-segredo-do-app

# Porta da API Express (o Vite faz proxy de /api para cá).
# API_PORT tem precedência sobre PORT (ferramentas de preview/hospedagem injetam PORT no processo).
API_PORT=3001
PORT=3001

# Origens liberadas no CORS (em dev, o Vite serve em http://localhost:5173).
CORS_ORIGIN=http://localhost:5173

# Em produção, URL pública da API (ex.: Render). Em dev, deixe vazio (usa o proxy do Vite).
VITE_API_URL=

# TRAVA DE SEGURANÇA do `npm run migrate`: trecho que DEVE aparecer no host da DATABASE_URL.
# Se não bater, o migrate RECUSA rodar. Existe porque uma connection string de PRODUÇÃO já
# circulou como se fosse de dev — sem esta trava, um `npm run migrate` criaria o schema lá.
# Antes de migrar qualquer banco, rode `npm run sonda` (somente leitura) e confira o veredito.
# Ex. (branch de dev): DB_BRANCH_ESPERADA=ep-restless-dawn
DB_BRANCH_ESPERADA=

# RF-B06 — teto do upload de anexo PELO APP (MB). Acima disso a API devolve 413: um BYTEA
# grande derruba a conexão do POOLER do Neon. Arquivos maiores entram pelo ETL, que usa
# conexão direta (ver ANEXO_MAX_MB / ANEXO_POOLER_MAX_MB do scripts/importar_orcamento.py).
ANEXO_UPLOAD_MAX_MB=25

# RF-H03 — chave para o módulo comercial consumir /api/integracao/* (header x-api-key).
# Gere um valor aleatório forte. Se vazio, os endpoints de integração ficam desativados.
INTEGRACAO_API_KEY=

# ETL de orçamentos (scripts/importar_orcamento.py) — limites de anexo, em MB.
# Até ANEXO_POOLER_MAX_MB o PDF entra na transação normal (via pooler); acima disso
# vai por conexão DIRETA do Neon (host sem '-pooler'). Acima de ANEXO_MAX_MB fica só local.
#ANEXO_POOLER_MAX_MB=25
#ANEXO_MAX_MB=100
